# Node modules — these are huge and rebuilt with `npm install`
# Committing them would bloat the repo and break across OS
node_modules/

# Environment files — contain secrets (DB password, JWT secret)
# Only .env.example is committed (the template)
.env
.env.local
.env.*.local

# Compiled TypeScript output — regenerated by `npm run build`
dist/
build/

# Test coverage reports — regenerated by `npm test`
coverage/

# Logs from any tool
*.log
npm-debug.log*
yarn-debug.log*

# IDE-specific files — different per developer machine
.vscode/*
!.vscode/settings.json     # exception: shared project settings
.idea/

# macOS metadata files
.DS_Store

# Vite build artefact
.vite/