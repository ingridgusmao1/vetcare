----------------------------------------------

CONTENU COMPLET :

    export function DashboardLayout() {
      const { user, logout } = useAuth();
      const navigate = useNavigate();

      const handleLogout = async () => {
        await logout();
        navigate('/login', { replace: true });
      };

      return (
        <div style={{ display: 'flex', minHeight: '100vh' }}>
          <a href="#main-content" className="skip-link">
            Aller au contenu principal
          </a>
          <Sidebar />

          <div style={{ flex: 1, display: 'flex', flexDirection: 'column' }}>
            <header style={{ height: 'var(--header-height)', ... }}>
              {user?.email} ({user?.role})
              <Button variant="secondary" size="sm" onClick={handleLogout}>
                Deconnexion
              </Button>
            </header>

            <main id="main-content" style={{ flex: 1, padding: 'var(--space-6)' }}>
              <Outlet />
            </main>
          </div>
        </div>
      );
    }

EXPLICATION :

  Skip link
    <a href="#main-content">Aller au contenu principal</a> — accessibilite
    WCAG 2.1. Les utilisateurs navigant au clavier peuvent sauter la sidebar
    et aller directement au contenu. Invisible par defaut, visible au focus.

  <Outlet />
    Point d'injection React Router. Les composants enfants (DashboardPage,
    PatientsPage...) sont rendus ici, a l'interieur du layout partage.

  replace: true sur logout
    Apres deconnexion, l'historique du dashboard est efface. L'utilisateur
    ne peut pas revenir au dashboard avec le bouton "retour".


8.8 COMPOSANT ATOM : src/components/atoms/Button.tsx
------------------------------------------------------

CONTENU COMPLET :

    interface ButtonProps extends ButtonHTMLAttributes<HTMLButtonElement> {
      variant?: 'primary' | 'secondary' | 'danger';
      size?: 'sm' | 'md';
      children: ReactNode;
    }

    export function Button({ variant = 'primary', size = 'md', children, style, ...rest }) {
      const base = {
        fontFamily: 'var(--font-body)',
        fontWeight: 500,
        letterSpacing: '0.05em',
        textTransform: 'uppercase',
        border: 'none',
        borderRadius: 'var(--radius-sm)',
        cursor: 'pointer',
        transition: 'opacity 0.2s, transform 0.1s',
        fontSize: size === 'sm' ? 'var(--fs-xs)' : 'var(--fs-sm)',
        padding: size === 'sm'
          ? 'var(--space-2) var(--space-4)'
          : 'var(--space-3) var(--space-6)',
      };

      const variants = {
        primary:   { background: 'var(--color-ink)', color: 'var(--color-text-on-ink)' },
        secondary: { background: 'transparent', color: 'var(--color-ink)',
                     border: '1px solid var(--color-ink)' },
        danger:    { background: 'var(--color-danger)', color: 'var(--color-text-on-ink)' },
      };

      const disabledStyle = rest.disabled ? { opacity: 0.5, cursor: 'not-allowed' } : {};

      return (
        <button {...rest} style={{ ...base, ...variants[variant], ...disabledStyle, ...style }}>
          {children}
        </button>
      );
    }

EXPLICATION :

  extends ButtonHTMLAttributes
    Le composant herite de tous les props natifs HTML du bouton (onClick,
    disabled, type, aria-label...). On n'a pas besoin de les redeclarer.

  ...rest
    Rest props — tout ce qui n'est pas variant, size, children, style est
    collecte dans rest et propage au <button> natif.

  Spread styles
    { ...base, ...variants[variant], ...disabledStyle, ...style }
    Les styles sont fusionnes dans l'ordre. Le style passe en prop (en
    dernier) peut surcharger n'importe quel style par defaut.


