          <div style={{ fontWeight: 600, letterSpacing: '0.2em' }}>
            VET<span style={{ color: 'var(--color-accent-light)' }}>CARE</span>
          </div>

          <nav aria-label="Navigation interne">
            <ul style={{ listStyle: 'none' }}>
              {NAV_ITEMS.map((item) => (
                <li key={item.to}>
                  <NavLink
                    to={item.to}
                    style={({ isActive }) => ({
                      display: 'block',
                      color: isActive ? 'var(--color-accent-light)' : 'var(--color-text-on-ink)',
                      borderLeft: isActive ? '2px solid var(--color-accent-light)' : '2px solid transparent',
                      textDecoration: 'none',
