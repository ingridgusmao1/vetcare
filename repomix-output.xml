// Convert ISO string to a French short date: "18 févr. 2026".
function formatDateFr(iso: string | null | undefined): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('fr-FR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
}

export function PatientsTable({
  patients,
  ownersById,
  onSoftDelete,
}: PatientsTableProps) {
