<file path="frontend/nginx.conf">
server {
    listen 80;
    server_name _;

    # Where the SPA's index.html and JS bundles live (copied by the Dockerfile).
    root /usr/share/nginx/html;
    index index.html;

    # ------------------------------------------------------------------------
    # API proxy — every /api/* request goes to the backend container.
    # "backend" is resolvable because docker-compose puts both services on the
    # same Docker network and registers each service name as a DNS alias.
    # ------------------------------------------------------------------------
    location /api/ {
        proxy_pass http://backend:4000/api/;

        # Forward the original Host so the backend can build correct redirects.
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Cookies need to flow both ways for the JWT auth.
        proxy_pass_request_headers on;
    }

    # ------------------------------------------------------------------------
    # SPA fallback — any URL that doesn't match a real file falls back to
    # index.html so React Router can handle the route on the client.
    # Without this, /dashboard refreshed in the browser returns 404.
    # ------------------------------------------------------------------------
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Long-cache static assets (JS / CSS bundles get content-hashed names).
    location ~* \.(js|css|png|jpg|jpeg|svg|woff2?)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
</file>

